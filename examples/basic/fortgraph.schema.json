{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/fortgraph.schema.json",
  "title": "FortGraph dependency graph",
  "description": "JSON structure accepted by the FortGraph HTML viewer.",
  "type": "object",
  "required": [
    "nodes",
    "edges"
  ],
  "properties": {
    "version": {
      "type": [
        "integer",
        "string"
      ],
      "description": "Optional FortGraph format version."
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "position": {
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "type",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "module",
            "subroutine",
            "external"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ]
        },
        "parentName": {
          "type": [
            "string",
            "null"
          ]
        },
        "position": {
          "$ref": "#/$defs/position"
        }
      },
      "additionalProperties": true
    },
    "edge": {
      "type": "object",
      "required": [
        "source",
        "target"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "use",
            "contains"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
